DATABASE_URL=postgresql://seroptrans:seroptrans_dev@localhost:5432/seroptrans
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Webhook n8n importación de horarios (POST JSON: id_proyecto, url)
N8N_HORARIOS_WEBHOOK_URL=https://n8nadm.admagentes.online/webhook/st_horarios

# Opcional: URL pública del API para enlaces de Excel subidos (ej. https://api.mi-dominio.com) si n8n no alcanza localhost
PUBLIC_BASE_URL=

# CORS en producción (separado por coma). Ej: https://app.tu-dominio.com
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Ruta de uploads en servidor/contendor (Docker: /app/uploads/horarios)
HORARIOS_UPLOAD_DIR=
