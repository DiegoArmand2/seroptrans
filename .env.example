# Copia a .env en el servidor (NO versionar) y ajusta valores.

# Postgres (compose)
POSTGRES_USER=seroptrans
POSTGRES_DB=seroptrans
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Backend (FastAPI)
SECRET_KEY=CHANGE_ME_LONG_RANDOM_SECRET
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS: el origen donde los usuarios abrirán el frontend (puerto 3000 si usas este compose)
CORS_ORIGINS=http://TU_DOMINIO_O_IP:3000

# URL pública del API (para links de archivos subidos consumidos por n8n)
# En docker-compose actual el host publica el API en el puerto 8000 (mapeo 8000:8000).
PUBLIC_BASE_URL=http://TU_DOMINIO_O_IP:8000

# n8n — importación horarios (POST JSON: id_proyecto, url). Vacío = usa URL por defecto en el backend.
N8N_HORARIOS_WEBHOOK_URL=https://n8nadm.admagentes.online/webhook/st_horarios

# Frontend (Vite build): URL literal alcanzable por el navegador (sin sintaxis ${...} de shell).
VITE_API_URL=http://TU_DOMINIO_O_IP:8000/api
