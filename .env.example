# Copia a .env en el servidor (NO versionar) y ajusta valores.

# Postgres (compose)
POSTGRES_USER=seroptrans
POSTGRES_DB=seroptrans
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Backend (FastAPI)
SECRET_KEY=CHANGE_ME_LONG_RANDOM_SECRET
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS: el origen donde los usuarios abrirán el frontend (puerto 3000 si usas este compose)
CORS_ORIGINS=http://TU_DOMINIO_O_IP:3000

# URL pública del API (para links de archivos subidos consumidos por n8n)
PUBLIC_BASE_URL=http://TU_DOMINIO_O_IP:8040

# n8n (opcional)
N8N_HORARIOS_WEBHOOK_URL=

# Frontend (Vite build): URL base de la API. Debe ser alcanzable por el navegador del usuario.
VITE_API_URL=http://TU_DOMINIO_O_IP:8040/api
